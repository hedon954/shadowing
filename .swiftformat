--swiftversion 6.0
--indent 4
--linebreaks lf
--trimwhitespace always
--self remove
--commas inline
--stripunusedargs closure-only
--exclude Shadowing/Shadowing.xcodeproj
# Keep explicit Sendable for Swift 6 clarity; avoid default-rule drift across SwiftFormat minors.
--disable preferCountWhere,redundantSendable
